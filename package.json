{
  "name": "digital-garden",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.21.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:css": "node scripts/check-css-layers.mjs",
    "lint:keys": "node scripts/check-key-drift.mjs",
    "lint:docs": "node scripts/check-doc-gate-sync.mjs && node scripts/check-doc-links.mjs",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@garden/oklch": "workspace:*",
    "@sanity/client": "^7.23.0",
    "next": "16.2.9",
    "next-sanity": "^13.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.2",
    "github-slugger": "^2.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
