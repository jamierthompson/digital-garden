# Studio env contract. Only vars prefixed SANITY_STUDIO_ are exposed to the
# Studio bundle. Copy to .env.local (gitignored) and adjust per environment.
# All values here are PUBLIC by nature (they ship in the Studio bundle).

# Front-end origin the Presentation tool loads in its iframe for Preview /
# Visual Editing. Defaults to the local Next.js app when unset. Point this at
# the deployed app per Studio deployment (e.g. your Vercel production URL);
# never hardcode a production URL in sanity.config.ts.
# Must be a valid ABSOLUTE origin (e.g. https://example.com) with NO trailing
# slash — the value passes straight through to previewUrl.initial, so a
# malformed value breaks the preview iframe at runtime.
SANITY_STUDIO_PREVIEW_URL=http://localhost:3000
