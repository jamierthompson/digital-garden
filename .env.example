# Public site origin — used to build absolute URLs in the RSS feed (/rss.xml).
# Public; no trailing slash. Defaults to http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sanity — these are public (shipped to the browser), not secrets.
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
# Pin to the date you set up the project; bump deliberately when adopting new APIs.
NEXT_PUBLIC_SANITY_API_VERSION=2026-06-21
# Where the standalone Studio is deployed — used for Visual Editing click-to-edit
# deep links. Public (ships in encoded preview strings). Defaults to /studio in dev.
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3333

# SECRET — server-side only, NEVER NEXT_PUBLIC_*. Grants dataset read incl. drafts;
# attached per request by defineLive (server-side) and the draft-mode enable handshake.
# A leak = permanent compromise (rotate in sanity.io/manage). Give it the narrowest
# scope that works (read, this dataset). Required for draft mode / Visual Editing.
SANITY_API_READ_TOKEN=your-read-token

# BROWSER token for standalone live-draft preview. Distinct from the read token above:
# next-sanity shares THIS one with the browser (via the SanityLive EventSource) when
# <SanityLive includeDrafts> opens a draft-capable live connection OUTSIDE the
# Presentation Tool. Because it reaches the browser, mint a DEDICATED token with the
# MINIMUM scope — Viewer (read) only — never the read/write token. NOT NEXT_PUBLIC_*
# (next-sanity exposes it through its own mechanism, not build-time inlining).
# OPTIONAL: leave unset and drafts still preview inside Presentation; only standalone
# browser live-draft preview stays off. Also add the app origin(s) to Sanity CORS
# (sanity.io/manage → API → CORS Origins, with credentials). [security-and-ops §1, §3]
SANITY_API_BROWSER_TOKEN=your-browser-viewer-token

# SECRET — server-side only, NEVER NEXT_PUBLIC_*. The shared secret for the Sanity
# publish→revalidate webhook (src/app/api/revalidate/route.ts). Paste the SAME value here
# (and in Vercel, per environment) and into the Sanity webhook config at sanity.io/manage:
# the handler verifies the request's HMAC signature against it before expiring cache tags.
# Absent → the webhook fails loud (500), never revalidates unverified. A leak lets anyone
# trigger revalidation; rotate it in both places if exposed. [build-phases #3]
SANITY_REVALIDATE_SECRET=your-webhook-secret
