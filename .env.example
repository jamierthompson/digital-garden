# Public site origin for absolute URLs in the RSS feed (/rss.xml). No trailing slash.
# Defaults to http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sanity — public (shipped to the browser), not secrets.
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-06-21 # pin to project setup date; bump deliberately
# Deployed Studio URL for Visual Editing deep links. Defaults to /studio in dev.
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3333

# SECRET (server-only, never NEXT_PUBLIC_*) — dataset read incl. drafts. Give it the narrowest
# scope (Viewer/read, this dataset); a leak = compromise, rotate at sanity.io/manage. Required
# for draft mode / Visual Editing. (see docs/handbook/security-and-ops.md)
SANITY_API_READ_TOKEN=your-read-token

# A DEDICATED Viewer (read-only) token next-sanity shares with the browser for standalone
# live-draft preview outside the Presentation Tool. Not NEXT_PUBLIC_*. Add the app origin(s) to
# Sanity CORS (with credentials). OPTIONAL: unset → drafts still preview inside Presentation;
# only standalone browser preview is off. (see docs/handbook/security-and-ops.md)
SANITY_API_BROWSER_TOKEN=your-browser-viewer-token

# SECRET (server-only) — shared secret for the Sanity publish→revalidate webhook
# (src/app/api/revalidate/route.ts). Paste the SAME value into Vercel and the Sanity webhook
# config; absent → the handler fails loud (500). Rotate in both places if exposed. (see docs/handbook/security-and-ops.md)
SANITY_REVALIDATE_SECRET=your-webhook-secret
