# Sanity — these are public (shipped to the browser), not secrets.
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
# Pin to the date you set up the project; bump deliberately when adopting new APIs.
NEXT_PUBLIC_SANITY_API_VERSION=2026-06-21
# Where the standalone Studio is deployed — used for Visual Editing click-to-edit
# deep links. Public (ships in encoded preview strings). Defaults to /studio in dev.
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3333

# SECRET — server-side only, NEVER NEXT_PUBLIC_*. Grants dataset read incl. drafts;
# attached per request in the draft-mode route handler. A leak = permanent compromise
# (rotate in sanity.io/manage). Only needed once draft mode / Visual Editing is used.
SANITY_API_READ_TOKEN=your-read-token
